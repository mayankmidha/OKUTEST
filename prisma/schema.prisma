generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payout {
  id              String   @id @default(cuid())
  practitionerId  String
  amount          Float
  currency        String   @default("INR")
  status          String   @default("PENDING") // PENDING, COMPLETED, FAILED
  referenceId     String?  // Bank transfer ref
  requestNote     String?
  processedAt     DateTime?
  periodStart     DateTime
  periodEnd       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  practitioner    User     @relation("PractitionerPayouts", fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([practitionerId])
}

model User {
  id                         String               @id @default(cuid())
  name                       String?
  email                      String               @unique
  referralCode               String?              @unique
  referredById               String?
  emailVerified              DateTime?
  image                      String?
  role                       UserRole             @default(CLIENT)
  password                   String?
  phone                      String?
  bio                        String?
  avatar                     String?
  location                   String?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  hasSignedConsent           Boolean              @default(false)
  twoFactorSecret            String?
  twoFactorEnabled           Boolean              @default(false)
  accounts                   Account[]
  clientAppointments         Appointment[]        @relation("ClientAppointments")
  practitionerAppointments   Appointment[]        @relation("PractitionerAppointments")
  createdAssessments         Assessment[]         @relation("CreatedAssessments")
  payouts                    Payout[]             @relation("PractitionerPayouts")
  facilitatedGroups          GroupSession[]       @relation("FacilitatedGroups")
  joinedGroups               GroupSessionParticipant[]
  assessmentAnswers          AssessmentAnswer[]
  assignedTasks              AssignedAssessment[] @relation("ClientAssignments")
  managedTasks               AssignedAssessment[] @relation("PractitionerAssignments")
  auditLogs                  AuditLog[]
  clientProfile              ClientProfile?
  clientDocuments            Document[]           @relation("ClientDocuments")
  practitionerDocuments      Document[]           @relation("PractitionerDocuments")
  informedConsents           InformedConsent[]
  intakeForm                 IntakeForm?
  receivedMessages           Message[]            @relation("ReceivedMessages")
  sentMessages               Message[]            @relation("SentMessages")
  moodEntries                MoodEntry[]
  notifications              Notification[]
  payments                   Payment[]
  posts                      Post[]
  practitionerProfile        PractitionerProfile?
  sessions                   Session[]
  tasks                      Task[]
  clientTreatmentPlans       TreatmentPlan[]      @relation("ClientTreatmentPlans")
  practitionerTreatmentPlans TreatmentPlan[]      @relation("PractitionerTreatmentPlans")
  activities                 UserActivity[]
  groupParticipations        GroupParticipant[]
  insurancePolicies          InsurancePolicy[]
  prescriptions              Prescription[]       @relation("ClientPrescriptions")
  authoredPrescriptions      Prescription[]       @relation("PractitionerPrescriptions")
  aiCareSessions             AiCareSession[]
  careContext                CareContext?
  
  // B2B Support
  organizationId             String?
  organization               Organization?        @relation(fields: [organizationId], references: [id])
  orgRole                    String?              @default("MEMBER") // ADMIN, MEMBER
  referredBy                 User?                @relation("UserReferrals", fields: [referredById], references: [id])
  referrals                  User[]               @relation("UserReferrals")
  earnedReferralRewards      ReferralReward[]     @relation("ReferralRewardReferrer")
  referralSourceRewards      ReferralReward[]     @relation("ReferralRewardReferredUser")
  notificationPreferences    NotificationPreference[]

  @@index([email])
  @@index([role])
  @@index([referredById])
}

model InformedConsent {
  id               String   @id @default(cuid())
  userId           String
  version          String   @default("1.0")
  signedAt         DateTime @default(now())
  ipAddress        String?
  userAgent        String?
  agreementContent String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AssignedAssessment {
  id                      String                  @id @default(cuid())
  clientId                String
  practitionerId          String
  assessmentId            String
  status                  String                  @default("PENDING")
  chargeAmount            Float                   @default(0)
  billingStatus           AssessmentBillingStatus @default(NOT_REQUIRED)
  processor               String?
  platformFeePercent      Float                   @default(0)
  platformFeeAmount       Float                   @default(0)
  practitionerPayoutAmount Float                  @default(0)
  createdAt               DateTime                @default(now())
  completedAt             DateTime?
  chargedAt               DateTime?
  assessment              Assessment              @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  client                  User                    @relation("ClientAssignments", fields: [clientId], references: [id], onDelete: Cascade)
  practitioner            User                    @relation("PractitionerAssignments", fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([practitionerId, billingStatus])
  @@index([clientId, billingStatus])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  category  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TreatmentPlan {
  id                String    @id @default(cuid())
  clientId          String
  practitionerId    String
  presentingProblem String
  goals             String
  objectives        String
  interventions     String
  status            String    @default("ACTIVE")
  nextReviewDate    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  client            User      @relation("ClientTreatmentPlans", fields: [clientId], references: [id], onDelete: Cascade)
  practitioner      User      @relation("PractitionerTreatmentPlans", fields: [practitionerId], references: [id], onDelete: Cascade)
}

model Task {
  id          String   @id @default(cuid())
  userId      String
  title       String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  
  // ADHD Atomization Support
  parentId    String?
  parent      Task?    @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks    Task[]   @relation("SubTasks")
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  readAt     DateTime?
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ClientProfile {
  id                    String             @id @default(cuid())
  userId                String             @unique
  isOnboarded           Boolean            @default(false)
  dateOfBirth           DateTime?
  gender                String?
  medicalHistory        String?
  noShowCount           Int                @default(0)
  referralCreditBalance Float              @default(0)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  emergencyContactName  String?
  emergencyContactPhone String?
  preferredLanguage     String?            @default("English")
  timezone              String?            @default("UTC")
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PractitionerProfile {
  id                       String                 @id @default(cuid())
  userId                   String                 @unique
  isOnboarded              Boolean                @default(false)
  licenseNumber            String?
  specialization           String[]
  bio                      String?
  hourlyRate               Float?
  indiaSessionRate         Float?
  internationalSessionRate Float?
  sessionDuration          Int                    @default(50)
  bufferDuration           Int                    @default(10)
  isVerified               Boolean                @default(false)
  canPostBlogs             Boolean                @default(false)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  npiNumber                String?
  education                String?
  experienceYears          Int?                   @default(0)
  linkedinUrl              String?
  websiteUrl               String?
  stripeAccountId          String?
  baseCurrency             String                 @default("INR")
  timezone                 String                 @default("UTC")
  
  // Universal Calendar Sync
  calendlyLink             String?
  googleCalendarEmail      String?
  googleRefreshToken       String?
  outlookCalendarEmail     String?
  outlookRefreshToken      String?
  appleCalendarEmail       String?
  appleAppSpecificPassword String?
  iCalSecret               String?                @default(cuid())
  syncEnabled              Boolean                @default(false)

  availability             Availability[]
  overrides                AvailabilityOverride[]
  blockedDates             BlockedDate[]
  services                 Service[]
  user                     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Availability {
  id                    String              @id @default(cuid())
  practitionerProfileId String
  dayOfWeek             Int
  startTime             String
  endTime               String
  practitionerProfile   PractitionerProfile @relation(fields: [practitionerProfileId], references: [id], onDelete: Cascade)
}

model AvailabilityOverride {
  id                    String              @id @default(cuid())
  practitionerProfileId String
  date                  DateTime
  startTime             String
  endTime               String
  isAvailable           Boolean             @default(true)
  practitionerProfile   PractitionerProfile @relation(fields: [practitionerProfileId], references: [id], onDelete: Cascade)
}

model BlockedDate {
  id                    String              @id @default(cuid())
  practitionerProfileId String
  date                  DateTime
  reason                String?
  practitionerProfile   PractitionerProfile @relation(fields: [practitionerProfileId], references: [id], onDelete: Cascade)
}

model PlatformSettings {
  id                               String   @id @default("global")
  maintenanceMode                  Boolean  @default(false)
  platformFeePercent               Float    @default(20.0)
  therapySessionPlatformFeePercent Float    @default(20.0)
  psychiatrySessionPlatformFeePercent Float  @default(20.0)
  assessmentPlatformFeePercent     Float    @default(20.0)
  minimumPayoutAmount              Float    @default(25.0)
  okuAiEnabled                     Boolean  @default(true)
  multilingualAiEnabled            Boolean  @default(true)
  autoTranslateTranscripts         Boolean  @default(true)
  adhdCareModeEnabled              Boolean  @default(true)
  requireConsentBeforeTranscription Boolean @default(true)
  transcriptRetentionDays          Int      @default(365)
  supportEmail                     String   @default("support@okutherapy.com")
  announcementTitle                String?
  announcementText                 String?
  updatedAt                        DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum RecurringPattern {
  NONE
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model Appointment {
  id               String              @id @default(cuid())
  clientId         String?
  practitionerId   String
  serviceId        String
  startTime        DateTime
  endTime          DateTime
  status           AppointmentStatus   @default(SCHEDULED)
  attendanceStatus String?
  noShowFeeCharged Float?
  notes            String?
  googleEventId    String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  reminderSent     Boolean             @default(false)
  isTrial          Boolean             @default(false)
  superbillGenerated Boolean             @default(false)
  trialDuration    Int?                @default(10)
  referralCreditApplied Float          @default(0)
  priceSnapshot    Float?
  pricingRegion    String?

  // Recurring Session Logic
  recurringPattern  RecurringPattern  @default(NONE)
  parentAppointmentId String?
  parentAppointment   Appointment?    @relation("RecurringSeries", fields: [parentAppointmentId], references: [id])
  childAppointments   Appointment[]   @relation("RecurringSeries")

  // Group Therapy Support
  isGroupSession   Boolean             @default(false)
  maxParticipants  Int                 @default(1)
  participants     GroupParticipant[]

  client           User?               @relation("ClientAppointments", fields: [clientId], references: [id], map: "Appointment_clientId_fkey")
  practitioner     User                @relation("PractitionerAppointments", fields: [practitionerId], references: [id], map: "Appointment_practitionerId_fkey")
  service          Service             @relation(fields: [serviceId], references: [id])
  payments         Payment[]
  soapNote         SoapNote?
  transcript       Transcript?
  claim            Claim?
  groupNote        GroupNote?
  referralReward   ReferralReward?

  @@index([clientId])
  @@index([practitionerId, startTime, status])
  @@index([serviceId])
  @@index([status])
  @@index([startTime])
  @@index([parentAppointmentId])
}

model GroupParticipant {
  id            String      @id @default(cuid())
  appointmentId String
  userId        String
  joinedAt      DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, userId])
  @@index([appointmentId])
  @@index([userId])
}

model Transcript {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  content       String
  detectedLanguage String?
  summary       String?
  sentiment     String?
  riskLevel     String?
  keyInsights   Json?
  sentimentScores Json?
  clinicalSignals Json?
  adhdSignals   Json?
  careRecommendations Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

enum SoapNoteStatus {
  DRAFT
  FINALIZED
}

model SoapNote {
  id             String         @id @default(cuid())
  appointmentId  String         @unique
  subjective     String
  objective      String
  assessment     String
  plan           String
  status         SoapNoteStatus @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  appointment    Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}


model Assessment {
  id            String               @id @default(cuid())
  title         String
  description   String?
  questions     Json
  isActive      Boolean              @default(true)
  price         Float                @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  creatorId     String?
  isCustom      Boolean              @default(false)
  creator       User?                @relation("CreatedAssessments", fields: [creatorId], references: [id])
  answers       AssessmentAnswer[]
  assignedTasks AssignedAssessment[]
}

model Service {
  id           String        @id @default(cuid())
  name         String        @unique
  description  String?
  duration     Int
  price        Float
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  practitioners PractitionerProfile[]
}

model GroupSession {
  id            String                  @id @default(cuid())
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  maxCapacity   Int                     @default(10)
  status        AppointmentStatus       @default(SCHEDULED)
  price         Float                   @default(1500)
  practitionerId String
  practitioner  User                    @relation("FacilitatedGroups", fields: [practitionerId], references: [id])
  participants  GroupSessionParticipant[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
}

model GroupSessionParticipant {
  id             String       @id @default(cuid())
  sessionId      String
  clientId       String
  session        GroupSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  client         User         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())
  hasPaid        Boolean      @default(false)

  @@unique([sessionId, clientId])
}

model MoodEntry {
  id        String        @id @default(cuid())
  userId    String
  mood      Int
  notes     String?
  tags      String[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade, map: "MoodEntry_userId_fkey")
}

model AssessmentAnswer {
  id           String        @id @default(cuid())
  userId       String
  assessmentId String
  answers      Json
  score        Float?
  result       String?
  completedAt  DateTime      @default(now())
  assessment   Assessment    @relation(fields: [assessmentId], references: [id], map: "AssessmentAnswer_assessmentId_fkey")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade, map: "AssessmentAnswer_userId_fkey")
}

model Payment {
  id              String        @id @default(cuid())
  appointmentId   String
  userId          String
  amount          Float
  platformFeePercent Float      @default(0)
  platformFeeAmount Float       @default(0)
  practitionerPayoutAmount Float @default(0)
  stripePaymentId String?
  processor       String?
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  appointment     Appointment   @relation(fields: [appointmentId], references: [id], map: "Payment_appointmentId_fkey")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Payment_userId_fkey")
}

model ReferralReward {
  id             String      @id @default(cuid())
  referrerId     String
  referredUserId String
  appointmentId  String      @unique
  rewardStep     Int
  rewardPercent  Float       @default(10)
  rewardAmount   Float
  status         String      @default("EARNED")
  createdAt      DateTime    @default(now())
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  referrer       User        @relation("ReferralRewardReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser   User        @relation("ReferralRewardReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([referredUserId, rewardStep])
  @@index([referrerId])
  @@index([referredUserId])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String
  resourceType String
  resourceId   String
  changes      String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IntakeForm {
  id                 String    @id @default(cuid())
  userId             String    @unique
  hasSignedConsent   Boolean   @default(false)
  hasAcceptedPrivacy Boolean   @default(false)
  medicalHistory     String?
  signedAt           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  currentAddress     String?
  emergencyContact1  String?
  emergencyContact2  String?
  legalName          String?
  permanentAddress   String?
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  excerpt   String?
  image     String?
  category  String?
  authorId  String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
}

model Document {
  id             String   @id @default(cuid())
  name           String
  url            String
  type           String
  uploadedBy     String
  createdAt      DateTime @default(now())
  clientId       String
  isPrivate      Boolean  @default(false)
  practitionerId String?
  client         User     @relation("ClientDocuments", fields: [clientId], references: [id], onDelete: Cascade)
  practitioner   User?    @relation("PractitionerDocuments", fields: [practitionerId], references: [id], onDelete: Cascade)
}

model AiCareSession {
  id            String   @id @default(cuid())
  userId        String   @unique
  startTime     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  summary       String?  @db.Text
  context       String?  // Added for body doubling context
  type          String?  // Added for session type (e.g. FOCUSING)
  dominantMood  String?
  riskDetected  Boolean  @default(false)
  careInsights  Json?    // Structured clinical insights for the human therapist
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CareContext {
  id                String   @id @default(cuid())
  userId            String   @unique
  longTermMemory    String?  @db.Text // AI's high-level understanding of the user
  currentStruggles  String[]
  recentWins        String[]
  executiveFunction Json?    // Current ADHD energy levels / spoon count
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  CLIENT
  THERAPIST
  ADMIN
}

enum NotificationType {
  SESSION_REMINDER
  MESSAGE_RECEIVED
  TREATMENT_UPDATE
  PAYMENT_SUCCESS
  CLINICAL_ALERT
}

model NotificationPreference {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  enabled   Boolean          @default(true)
  channel   String           @default("EMAIL") // EMAIL, SMS, PUSH
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

enum AppointmentStatus {
  PENDING
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  EXTERNAL_BLOCK
  RESCHEDULED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum AssessmentBillingStatus {
  NOT_REQUIRED
  PENDING
  COMPLETED
  FAILED
  WAIVED
}

model InsurancePolicy {
  id                String   @id @default(cuid())
  userId            String
  providerName      String
  policyNumber      String
  groupNumber       String?
  status            String   @default("PENDING_VERIFICATION")
  isPrimary         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  claims            Claim[]

  @@index([userId])
}

model Claim {
  id                String      @id @default(cuid())
  policyId          String
  appointmentId     String      @unique
  status            String      @default("DRAFT")
  claimAmount       Float
  insurancePaid     Float?
  patientOwes       Float?
  filedAt           DateTime?
  policy            InsurancePolicy @relation(fields: [policyId], references: [id])
  appointment       Appointment     @relation(fields: [appointmentId], references: [id])

  @@index([policyId])
}

model Prescription {
  id                String   @id @default(cuid())
  clientId          String
  practitionerId    String
  medicationName    String
  dosage            String
  frequency         String
  startDate         DateTime
  endDate           DateTime?
  instructions      String?
  refills           Int      @default(0)
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  client            User     @relation("ClientPrescriptions", fields: [clientId], references: [id], onDelete: Cascade)
  practitioner      User     @relation("PractitionerPrescriptions", fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([practitionerId])
}

model GroupNote {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  theme         String?
  summary       String?     @db.Text
  groupDynamics String?     @db.Text
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Organization {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  type              String   // CORPORATE, SCHOOL, HOSPITAL
  logo              String?
  billingEmail      String
  subscriptionPlan  String   @default("BASIC")
  maxMembers        Int      @default(10)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  users             User[]
  contracts         Contract[]

  @@index([slug])
}

model Contract {
  id                String      @id @default(cuid())
  organizationId    String
  startDate         DateTime
  endDate           DateTime
  contractValue     Float
  status            String      @default("ACTIVE") // ACTIVE, EXPIRED, PENDING
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}
