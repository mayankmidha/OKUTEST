# ── Core ────────────────────────────────────────────────────────────────
AUTH_SECRET=                          # nextauth secret (openssl rand -base64 32)
DATABASE_URL=                         # postgresql://...
NEXT_PUBLIC_APP_URL=https://okutherapy.com

# ── Video Sessions (Stream.io) ──────────────────────────────────────────
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_SECRET_KEY=

# ── AI Features (Google Gemini) ─────────────────────────────────────────
GEMINI_API_KEY=

# ── Payments ────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=                    # optional — for international cards
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=                       # resend.com API key
ADMIN_EMAIL=admin@okutherapy.com      # receives admin alerts

# ── Security & Encryption ────────────────────────────────────────────────
EHR_ENCRYPTION_KEY=                   # 32-byte hex key for EHR data at rest
CRON_SECRET=                          # secret for /api/cron/* Bearer auth

# ── Rate Limiting (Upstash Redis) — optional ─────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
